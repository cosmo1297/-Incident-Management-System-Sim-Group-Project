    print("Incident Management System (Development Version)")
    print("One-third of the project is completed.\n")
    print("Completed:")
    print("- User, Admin, Analyst classes")
    print("- Incident class")
    print("- QueueClass imported")
    print("- IncidentManager started\n")


if __name__ == "__main__":
    main()
